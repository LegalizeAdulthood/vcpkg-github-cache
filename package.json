{
  "name": "vcpkg-github-cache",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Actions for vcpkg binary caching through GitHub Packages",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:setup && npm run build:analyze && npm run fix-dist-text && npm run check-dist-syntax",
    "build:setup": "ncc build src/setup.ts --out setup/dist --source-map --license licenses.txt",
    "build:analyze": "ncc build src/analyze.ts --out analyze/dist --source-map --license licenses.txt",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run build",
    "check-dist-syntax": "node --check setup/dist/index.js && node --check analyze/dist/index.js",
    "fix-dist-text": "node scripts/fix-dist-text.mjs setup/dist analyze/dist",
    "format": "prettier --write \"*.{json,mjs}\" \"scripts/**/*.mjs\" \"{src,test}/**/*.ts\" \"{setup,analyze}/action.yml\"",
    "format:check": "prettier --check \"*.{json,mjs}\" \"scripts/**/*.mjs\" \"{src,test}/**/*.ts\" \"{setup,analyze}/action.yml\"",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^9.30.0",
    "prettier": "^3.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "endOfLine": "auto",
    "printWidth": 80
  }
}
